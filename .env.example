# ============================================================================
# AUXR contract deployment environment
# ----------------------------------------------------------------------------
# Copy this file to .env (already gitignored) and fill in real values
# before deploying to Base Sepolia or Base mainnet.
#
# Required for `npm run contracts:deploy:*`:
# ============================================================================

# Deployer EOA private key (64 hex chars, NO 0x prefix).
# Fund this address with Base ETH before deploying.
PRIVATE_KEY=

# Admin address that will hold DEFAULT_ADMIN / MINTER / PAUSER roles after
# deploy. If unset, the deployer EOA becomes the admin. Production-grade
# deployments should set this to a Safe multisig.
ADMIN_ADDRESS=

# Base mainnet RPC. Get one from Alchemy / Infura / Quicknode. The public
# default https://mainnet.base.org is rate-limited and unreliable for deploys.
BASE_RPC_URL=

# Base Sepolia testnet RPC. Default https://sepolia.base.org works for
# testing; for higher throughput use an Alchemy / Infura URL.
BASE_SEPOLIA_RPC=

# Basescan API key for contract source verification.
# Sign up at https://basescan.org/myapikey
BASESCAN_API_KEY=

# Optional: enable gas reporter in test runs (`REPORT_GAS=true npm run contracts:test`)
REPORT_GAS=false
