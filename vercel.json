{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["fra1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/oracle",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/verify-pending-transfers",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/scan-deposits",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/send-monthly-statements",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/staking-reminders",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/execute-all",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/email-drip",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/store-daily-close",
      "schedule": "0 21 * * 1-5"
    },
    {
      "path": "/api/cron/daily-price-alert",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/health-monitor",
      "schedule": "*/15 * * * *"
    }
  ]
}