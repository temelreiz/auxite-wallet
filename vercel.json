{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": [
    "fra1"
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/rwa-io-push",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/activity-report?notify=1",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/oracle",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/verify-pending-transfers",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/scan-deposits",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/scan-user-deposits",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/send-monthly-statements",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/execute-all",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/stripe-cleanup-incomplete",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/card-recovery-email",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/email-drip",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/winback-email",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/kyc-reminder-push",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/daily-news-thread",
      "schedule": "30 10 * * 1-5"
    },
    {
      "path": "/api/cron/weekly-news-recap",
      "schedule": "0 17 * * 5"
    },
    {
      "path": "/api/cron/weekly-blog-draft",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/reconcile-deferred-onchain",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/hot-wallet-alert",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/store-daily-close",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/daily-price-alert",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/health-monitor",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/abaxx-sync",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/hedge-signal",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/rwa-nav-push",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/rwa-mint-sync",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/procure",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/scan-auxr-deposits",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/auxm-reconcile",
      "schedule": "30 8 * * *"
    },
    {
      "path": "/api/cron/bridge-offramp-sweep",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/reserve-attestation-post",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/auxr-ops-watch",
      "schedule": "*/5 * * * *"
    }
  ]
}